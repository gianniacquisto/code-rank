<%# locals: (technology:, starred:) %>
<% if authenticated? %>
  <% if starred %>
    <%= button_to technology_unstar_star_path(technology_id: technology.id), method: :delete, class: "star-btn star-active", id: "star-#{technology.id}", data: { turbo_frame: "_top" } do %>
      <svg class="star-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    <% end %>
  <% else %>
    <%= button_to technology_stars_path(technology_id: technology.id), method: :post, class: "star-btn star-inactive", id: "star-#{technology.id}", data: { turbo_frame: "_top" } do %>
      <svg class="star-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    <% end %>
  <% end %>
<% else %>
  <span class="star-btn star-inactive disabled" title="Log in to star this project">
    <svg class="star-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  </span>
<% end %>
